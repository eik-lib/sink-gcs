{
  "name": "@eik/sink-gcs",
  "version": "3.0.25",
  "description": "Sink for Google Cloud Storage",
  "main": "lib/main.js",
  "types": "./types/main.d.ts",
  "type": "module",
  "files": [
    "CHANGELOG.md",
    "package.json",
    "README.md",
    "lib",
    "types"
  ],
  "scripts": {
    "clean": "node -e \"['.tap', 'node_modules', 'types'].forEach(d => require('fs').rmSync(d, {recursive: true, force: true}))\"",
    "test": "node --test 'test/**/*.js'",
    "test:snapshots": "node --test --test-update-snapshots 'test/**/*.js'",
    "lint:fix": "eslint --fix .",
    "lint": "eslint .",
    "types": "run-s types:module types:test",
    "types:module": "tsc",
    "types:test": "tsc --project tsconfig.test.json"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:eik-lib/sink-gcs.git"
  },
  "author": "Trygve Lie",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/eik-lib/sink-gcs/issues"
  },
  "homepage": "https://github.com/eik-lib/sink-gcs#readme",
  "dependencies": {
    "@eik/common": "5.1.32",
    "@eik/sink": "1.2.7",
    "@google-cloud/storage": "7.21.0",
    "@metrics/client": "2.5.5"
  },
  "devDependencies": {
    "@eik/eslint-config": "2.0.7",
    "@eik/prettier-config": "1.0.2",
    "@eik/semantic-release-config": "1.0.17",
    "@eik/typescript-config": "1.0.2",
    "@types/readable-stream": "4.0.23",
    "eslint": "10.4.0",
    "npm-run-all2": "9.0.1",
    "prettier": "3.8.3",
    "semantic-release": "25.0.3",
    "typescript": "6.0.3"
  }
}
